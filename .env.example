# Neon / Prisma database connection strings
# Use pooled connection for normal application queries.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"

# Use direct connection for Prisma migrations when required.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"

# OpenAI API config for live discovery/enrichment
OPENAI_API_KEY="your_openai_api_key_here"
DEFAULT_RESEARCH_MODEL="gpt-5.5"
QUICK_RESEARCH_MODEL="gpt-4o-mini"

# Tavily API config for live discovery/enrichment
TAVILY_API_KEY="your_tavily_api_key_here"
SEARCH_PROVIDER="tavily"

