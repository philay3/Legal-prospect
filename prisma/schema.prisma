// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ConfidenceLevel {
  HIGH
  MEDIUM
  LOW
  UNKNOWN
}

enum VerificationStatus {
  CANDIDATE
  PENDING_REVIEW
  VERIFIED
  REJECTED
  STALE
}

enum SourceType {
  BAR_DIRECTORY
  GOOGLE_MAPS
  WEB_SCRAPE
  MANUAL
  MANUAL_SEED
}

model Firm {
  id                 String             @id @default(uuid())
  slug               String?            @unique
  firmName           String
  zip                String
  zipExt             String?
  city               String
  state              String
  streetAddress      String?
  website            String?
  phone              String?
  email              String?
  emailCheckedAt     DateTime?
  emailSource        DataPointSource?
  emailConfidence    Float?
  phoneSource        DataPointSource?
  phoneConfidence    Float?
  practiceAreas      String[]
  attorneyCountRange String
  attorneys          String[]
  attorneyList       Attorney[]
  areaLinks          FirmPracticeArea[]
  sourceType         SourceType
  sourceUrl          String?
  confidenceLevel    ConfidenceLevel    @default(UNKNOWN)
  verificationStatus VerificationStatus @default(CANDIDATE)
  lastCheckedDate    DateTime?
  globalNotes        String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  searchZip          String?
  savedLeads         SavedLead[]
  activities         Activity[]
  researchRuns       ResearchRun[]
  dataPoints         DataPoint[]

  @@index([zip])
  @@index([city, state])
  @@index([searchZip])
}

model Attorney {
  id        String   @id @default(uuid())
  firmId    String
  firm      Firm     @relation(fields: [firmId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([firmId, name])
  @@index([firmId])
}

model PracticeArea {
  id        String             @id @default(uuid())
  name      String             @unique
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  firmLinks FirmPracticeArea[]
}

model FirmPracticeArea {
  firmId         String
  practiceAreaId String
  firm           Firm         @relation(fields: [firmId], references: [id], onDelete: Cascade)
  practiceArea   PracticeArea @relation(fields: [practiceAreaId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@id([firmId, practiceAreaId])
  @@index([practiceAreaId])
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  sessions    Session[]
  savedLeads  SavedLead[]
  feedback    Feedback[]
  activities  Activity[]
}

model LoginCode {
  id           String    @id @default(uuid())
  email        String
  codeHash     String
  expiresAt    DateTime
  usedAt       DateTime?
  attemptCount Int       @default(0)
  createdAt    DateTime  @default(now())

  @@index([email])
}

model Session {
  id         String   @id @default(uuid())
  tokenHash  String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId])
}

enum LeadStatus {
  ACTIVE
  WON
  LOST
}

model SavedLead {
  id        String     @id @default(uuid())
  userId    String
  firmId    String
  status    LeadStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@unique([userId, firmId])
}

model Feedback {
  id        String   @id @default(uuid())
  choice    String
  message   String?
  userId    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum ActivityType {
  SEARCHED
  SAVED
  WON
  LOST
}

model Activity {
  id        String       @id @default(uuid())
  userId    String
  type      ActivityType
  firmId    String?      // set for SAVED / WON / LOST; null for SEARCHED
  query     String?      // the ZIP for SEARCHED; null for firm events
  count     Int?
  createdAt DateTime     @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  firm Firm? @relation(fields: [firmId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

enum ResearchTrigger {
  DISCOVERY
  SAVE
  SCHEDULED
}

enum FetchProvider {
  JINA
  DIRECT
  TAVILY
}

enum CheckOutcome {
  SUCCESS
  EMPTY
  ERROR
}

model ResearchRun {
  id            String          @id @default(uuid())
  firm          Firm?           @relation(fields: [firmId], references: [id], onDelete: SetNull)
  firmId        String?
  firmName      String?         // denormalized, kept even if firmId could not resolve
  searchZip     String?
  trigger       ResearchTrigger
  startedAt     DateTime
  finishedAt    DateTime?
  createdAt     DateTime        @default(now())
  websiteChecks WebsiteCheck[]

  @@index([firmId])
  @@index([searchZip])
}

model WebsiteCheck {
  id            String        @id @default(uuid())
  researchRun   ResearchRun   @relation(fields: [researchRunId], references: [id], onDelete: Cascade)
  researchRunId String
  url           String
  provider      FetchProvider
  httpStatus    Int?          // null when the failure carried no status (e.g. an abort)
  outcome       CheckOutcome
  errorMessage  String?
  createdAt     DateTime      @default(now())

  @@index([researchRunId])
}

enum DataField {
  EMAIL
  PHONE
}

enum DataPointSource {
  FIRM_DOMAIN       // email domain matches the firm's own website host
  OFF_DOMAIN        // email on a domain that isn't the firm's site
  GENERIC_PROVIDER  // email on a consumer provider (gmail, yahoo, ...)
  UNVERIFIED        // no website to corroborate against
  PLACES            // phone from Google Places
  WEBSITE           // phone observed from a website
}

model DataPoint {
  id         String          @id @default(uuid())
  firm       Firm            @relation(fields: [firmId], references: [id], onDelete: Cascade)
  firmId     String
  field      DataField
  value      String
  source     DataPointSource
  confidence Float
  observedAt DateTime        @default(now())
  createdAt  DateTime        @default(now())

  @@index([firmId, field])
}



